---
import { nav } from '../data/landing';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-md border-b border-border">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="#top" class="text-2xl font-bold tracking-tight text-text-main hover:text-primary transition-colors">
      Equiny
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {nav.map(item => (
        <a 
          href={item.href} 
          class="text-sm font-medium text-text-secondary hover:text-text-main transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a 
      href="#download" 
      class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-background font-semibold text-sm hover:bg-primary-dark transition-colors"
    >
      Baixar
    </a>

    <!-- Mobile menu button (visual only for this demo) -->
    <button class="md:hidden p-2 text-text-secondary hover:text-text-main" aria-label="Menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>
