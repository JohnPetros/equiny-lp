---
import { securityBullets } from '../data/landing';
---

<div class="grid lg:grid-cols-2 gap-16 items-center">
  <div>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-text-main mb-6">
      Segurança em Primeiro Lugar
    </h2>
    <p class="text-lg text-text-secondary leading-relaxed mb-10">
      Levamos a sério a integridade da comunidade equestre. Todas as interações são monitoradas para garantir um ambiente saudável.
    </p>
    
    <ul class="space-y-6">
      {securityBullets.map(bullet => (
        <li class="flex items-start gap-4">
          <div class="mt-1 w-6 h-6 rounded-full bg-primary/10 text-primary flex items-center justify-center shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-text-main font-medium">{bullet.text}</span>
            {bullet.badge && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-surface border border-border text-text-secondary">
                {bullet.badge}
              </span>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
  
  <div class="hidden lg:flex justify-end">
    <div class="relative w-full max-w-md aspect-square rounded-[40px] bg-surface border border-border flex items-center justify-center overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-50"></div>
      
      <div class="relative z-10 w-32 h-32 text-primary/20 group-hover:text-primary/40 transition-colors duration-500">
        <svg width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
      
      <!-- Decorative elements -->
      <div class="absolute top-1/4 left-1/4 w-2 h-2 rounded-full bg-primary/30"></div>
      <div class="absolute bottom-1/3 right-1/4 w-3 h-3 rounded-full bg-primary/20"></div>
      <div class="absolute top-1/2 right-1/3 w-1.5 h-1.5 rounded-full bg-primary/40"></div>
    </div>
  </div>
</div>
