---
import StoreButtons from './StoreButtons.astro';
import { appPublished } from '../data/landing';
---

<div class="relative max-w-5xl mx-auto p-10 md:p-16 rounded-[40px] bg-surface border border-border text-center overflow-hidden">
  <!-- Decorative glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-lg h-64 bg-primary/10 blur-[80px] rounded-full pointer-events-none"></div>
  
  <div class="relative z-10">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-text-main mb-6">
      Pronto para encontrar o par ideal?
    </h2>
    <p class="text-lg text-text-secondary mb-10 max-w-2xl mx-auto">
      Baixe o Equiny agora e faça parte da maior comunidade de criadores.
    </p>
    
    <div class="flex justify-center mb-8">
      <StoreButtons />
    </div>
    
    <p class="text-sm text-text-secondary">
      {appPublished ? 'Disponível para iOS e Android.' : 'Disponível em breve para iOS e Android'}
    </p>
  </div>
</div>
