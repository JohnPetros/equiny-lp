---
import { previewCards } from '../data/landing';
import chatImage from '@/src/assets/chat.png';
import feedImage from '@/src/assets/feed.png';
import horseProfileImage from '@/src/assets/horse-profile.png';
import matchesImage from '@/src/assets/matches.png';
---

<div data-preview-carousel class="w-full overflow-x-auto pb-8 -mx-6 px-6 md:mx-0 md:px-0 scroll-smooth snap-x snap-mandatory hide-scrollbar">
  <div class="flex md:grid md:grid-cols-2 lg:grid-cols-4 gap-6 min-w-max md:min-w-0">
    {previewCards.map((card, index) => (
      <div class="w-[280px] md:w-auto shrink-0 snap-center">
        <div data-preview-card class="relative h-[560px] md:h-[620px] lg:h-[640px] rounded-[32px] bg-[#0B0B0D] border border-border overflow-hidden group shadow-2xl preview-card" style={`--card-index: ${index};`}>
          
          <div class="absolute inset-0 transition-transform duration-700 group-hover:scale-[1.02]">
            {card.type === 'feed' && (
              <div class="w-full h-full relative bg-[#101015]">
                <img src={feedImage.src} alt="Preview do feed" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
            )}

            {card.type === 'profile' && (
              <div class="w-full h-full relative bg-[#0B0B0D]">
                <img src={horseProfileImage.src} alt="Preview do perfil" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
            )}

            {card.type === 'matches' && (
              <div class="w-full h-full relative bg-[#0B0B0D]">
                <img src={matchesImage.src} alt="Preview de matches" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
            )}

            {card.type === 'chat' && (
              <div class="w-full h-full relative bg-[#0B0B0D]">
                <img src={chatImage.src} alt="Preview do chat" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              </div>
            )}
          </div>

          <!-- Content overlay (hidden to show full UI, or we can keep it on hover) -->
          <div class="absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-surface via-surface/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20 pointer-events-none">
            <h4 class="text-xl font-bold text-text-main mb-1">{card.title}</h4>
            <p class="text-sm text-text-secondary">{card.description}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  const carousel = document.querySelector('[data-preview-carousel]');
  const cards = carousel?.querySelectorAll('[data-preview-card]');

  if (carousel && cards?.length) {
    carousel.classList.add('animate-on-scroll');

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.25, rootMargin: '0px 0px -8% 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }
</script>

<style>
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .animate-on-scroll .preview-card {
    opacity: 0;
    transform: translateY(36px) rotate(-5deg) scale(0.96);
    transform-origin: 50% 85%;
    transition: opacity 700ms ease, transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--card-index) * 110ms);
    will-change: transform, opacity;
  }

  .animate-on-scroll .preview-card.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-on-scroll .preview-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
