---
import { appPublished } from '../data/landing';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`flex flex-col sm:flex-row items-center gap-4 ${className}`}>
  <a 
    href="#download" 
    class="relative group flex items-center justify-center gap-3 w-full sm:w-auto px-6 py-3.5 bg-surface border border-border rounded-xl hover:border-primary/50 transition-all duration-300"
  >
    {!appPublished && (
      <span class="absolute -top-3 -right-2 bg-primary text-background text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shadow-lg shadow-primary/20">
        Em breve
      </span>
    )}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-text-main">
      <path d="M16.365 21.444c-1.32.96-2.616.936-3.96.024-1.32-.888-2.592-1.008-3.912-.024-1.632 1.2-3.216.84-4.512-.984-3.168-4.464-3.504-10.128-.864-12.768 1.512-1.512 3.24-1.848 4.632-1.08 1.176.648 2.016.624 3.168 0 1.584-.84 3.432-.6 4.752.696.168.168.312.336.456.528-2.424 1.416-2.88 4.488-.936 6.168.432.384.936.672 1.464.864-1.008 2.952-2.736 5.016-4.284 6.576zM15.405 6.648c-.84 1.008-2.184 1.56-3.408 1.344-.24-1.464.48-2.856 1.368-3.816.864-1.008 2.256-1.608 3.456-1.344.24 1.512-.528 2.856-1.416 3.816z"/>
    </svg>
    <div class="flex flex-col items-start">
      <span class="text-[10px] text-text-secondary leading-none mb-1">Baixar na</span>
      <span class="text-sm font-semibold text-text-main leading-none">App Store</span>
    </div>
  </a>

  <a 
    href="#download" 
    class="relative group flex items-center justify-center gap-3 w-full sm:w-auto px-6 py-3.5 bg-surface border border-border rounded-xl hover:border-primary/50 transition-all duration-300"
  >
    {!appPublished && (
      <span class="absolute -top-3 -right-2 bg-primary text-background text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full shadow-lg shadow-primary/20">
        Em breve
      </span>
    )}
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-text-main">
      <path d="M3.609 1.814L13.792 12l-10.183 10.186c-.165-.138-.309-.311-.421-.514C2.96 21.258 2.84 20.784 2.84 20.25V3.75c0-.534.12-1.008.348-1.422.112-.203.256-.376.421-.514zm11.232 11.232l3.414 3.414-12.72 7.344 9.306-10.758zm.96-1.116l4.224 2.436c.864.498.864 1.308 0 1.806l-4.224 2.436-3.66-3.66 3.66-3.018zm-1.056-1.224L5.439.948l12.72 7.344-3.414 3.414z"/>
    </svg>
    <div class="flex flex-col items-start">
      <span class="text-[10px] text-text-secondary leading-none mb-1">Disponível no</span>
      <span class="text-sm font-semibold text-text-main leading-none">Google Play</span>
    </div>
  </a>
</div>
