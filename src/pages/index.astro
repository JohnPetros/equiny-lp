---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import StoreButtons from '../components/StoreButtons.astro';
import SectionHeader from '../components/SectionHeader.astro';
import StepCard from '../components/StepCard.astro';
import BenefitCard from '../components/BenefitCard.astro';
import SecurityBlock from '../components/SecurityBlock.astro';
import MockPhoneStack from '../components/MockPhoneStack.astro';
import PreviewCarousel from '../components/PreviewCarousel.astro';
import FAQ from '../components/FAQ.astro';
import CTABox from '../components/CTABox.astro';
import Footer from '../components/Footer.astro';
import { steps, benefits } from '../data/landing';
---

<BaseLayout title="Equiny - O Tinder dos Cavalos" description="Encontre o par ideal pro seu cavalo, em poucos swipes.">
  <Navbar />

  <main class="pt-20">
    <!-- Hero Section -->
    <section id="top" class="relative min-h-[90vh] flex items-center pt-16 pb-32 overflow-hidden">
      <!-- Background Glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/20 blur-[120px] rounded-full pointer-events-none mix-blend-screen"></div>
      
      <div class="max-w-7xl mx-auto px-6 w-full relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-8 items-center">
          <div class="max-w-2xl" data-reveal>
            <div class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-semibold mb-8" data-reveal>
              <span class="mr-2">✨</span> O Tinder dos Cavalos
            </div>
            
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-text-main mb-6 leading-[1.1]" data-reveal>
              Encontre o par ideal pro seu cavalo, em poucos swipes.
            </h1>
            
            <p class="text-lg md:text-xl text-text-secondary leading-relaxed mb-10 max-w-xl" data-reveal>
              Cadastre seu cavalo, use filtros avançados, dê like e comece a conversar só quando houver um match mútuo. Simples, seguro e discreto.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center gap-6" data-reveal>
              <StoreButtons />
              <a href="#como-funciona" class="text-text-main font-medium hover:text-primary transition-colors flex items-center gap-2 group">
                Ver como funciona
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>
          
          <div class="relative" data-reveal>
            <MockPhoneStack />
          </div>
        </div>
      </div>
    </section>

    <!-- Como Funciona Section -->
    <section id="como-funciona" class="py-32 bg-background-alt">
      <div class="max-w-7xl mx-auto px-6">
        <div data-reveal>
          <SectionHeader 
          titleSmall="COMO FUNCIONA" 
          titleLarge="Quatro passos para o match" 
          />
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-20" data-reveal-stagger>
          {steps.map((step, index) => (
            <div data-reveal>
              <StepCard 
                title={step.title}
                description={step.description}
                icon={step.icon}
                index={index + 1}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefícios Section -->
    <section class="py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8" data-reveal-stagger>
          {benefits.map(benefit => (
            <div data-reveal>
              <BenefitCard 
                title={benefit.title}
                description={benefit.description}
                icon={benefit.icon}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Segurança Section -->
    <section id="seguranca" class="py-32 bg-background-alt overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <div data-reveal>
          <SecurityBlock />
        </div>
      </div>
    </section>

    <!-- Preview Section -->
    <section class="py-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <div data-reveal>
          <SectionHeader 
          titleSmall="PREVIEW DO APP" 
          titleLarge="Uma experiência premium na palma da mão" 
          />
        </div>
        <div class="mt-20" data-reveal>
          <PreviewCarousel />
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section id="download" class="py-32 bg-background-alt">
      <div class="max-w-7xl mx-auto px-6">
        <div data-reveal>
          <CTABox />
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-32">
      <div class="max-w-7xl mx-auto px-6">
        <div data-reveal>
          <SectionHeader 
          titleSmall="DÚVIDAS" 
          titleLarge="Perguntas Frequentes" 
          />
        </div>
        <div class="mt-16" data-reveal>
          <FAQ />
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const revealEls = document.querySelectorAll('[data-reveal]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      revealEls.forEach((el) => el.classList.add('is-visible'));
    } else if (revealEls.length) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          });
        },
        { threshold: 0.2, rootMargin: '0px 0px -10% 0px' }
      );

      revealEls.forEach((el) => observer.observe(el));
    }
  </script>

  <style>
    [data-reveal] {
      opacity: 0;
      transform: translateY(28px) scale(0.98);
      transition: opacity 650ms ease, transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform, opacity;
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: none;
    }

    [data-reveal-stagger] > [data-reveal]:nth-child(1) { transition-delay: 60ms; }
    [data-reveal-stagger] > [data-reveal]:nth-child(2) { transition-delay: 140ms; }
    [data-reveal-stagger] > [data-reveal]:nth-child(3) { transition-delay: 220ms; }
    [data-reveal-stagger] > [data-reveal]:nth-child(4) { transition-delay: 300ms; }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>
</BaseLayout>
